            box-shadow: var(--shadow-soft);
        }

        /* Testimony specific styles */
        .testimony-container {
            max-width: 900px;
            margin: 4rem auto;
            padding: 0 15px;
        }

        /* Lightbox Styling */
        .lightbox {
            display: none;
            position: fixed;
            z-index: 1100;
            padding-top: 80px;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(44, 58, 48, 0.95);
            backdrop-filter: blur(10px);
        }

        .lightbox-content {
            margin: auto;
            display: block;
            width: 85%;
            max-width: 750px;
        }

        #lightbox-img {
            width: 100%;
            height: auto;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            border: 4px solid rgba(255, 255, 255, 0.1);
        }

        #lightbox-caption {
            text-align: center;
            color: var(--color-accent);
            padding: 20px 0;
            font-size: 1.25rem;
            font-family: var(--font-heading);
        }

        .close {
            position: absolute;
            top: 25px;
            right: 35px;
            color: #fff;
            font-size: 45px;
            font-weight: 300;
            transition: var(--transition-smooth);
            cursor: pointer;
        }

        .close:hover {
            color: var(--color-accent);
            transform: rotate(90deg);
        }

        .prev,
        .next {
            cursor: pointer;
            position: absolute;
            top: 50%;
            width: auto;
            padding: 20px;
            margin-top: -50px;
            color: white;
            font-weight: bold;
            font-size: 24px;
            transition: var(--transition-smooth);
            user-select: none;
            border-radius: 50%;
            background-color: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            width: 60px;
            height: 60px;
        }

        .next {
            right: 30px;
        }

        .prev {
            left: 30px;
        }

        .prev:hover,
        .next:hover {
            background-color: var(--color-accent);
            color: var(--color-primary);
        }

        /* Media Queries for responsive layout */
        @media (max-width: 768px) {
            .main-hero h1 {
                font-size: 2.5rem;
            }

            .feature-content,
            .feature-content.reverse {
                flex-direction: column;
                text-align: center;
                gap: 2rem;
            }

            .feature-text {
                text-align: center;
            }

            .founder-content {
                flex-direction: column;
                text-align: center;
                gap: 2rem;
            }

            .founder-bio {
                text-align: center;
            }

            .article-list {
                grid-template-columns: 1fr;
                gap: 20px;
            }

            .team-members-sub {
                flex-direction: column;
                gap: 2rem;
                align-items: center;
            }

            .page-inverted h1,
            .about-page-inverted h1 {
                font-size: 2.5rem;
            }
        }
    </style>
</head>

