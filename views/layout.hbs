        .mission-icon-wrapper {
            flex-shrink: 0;
            width: 3.2rem;
            height: 3.2rem;
            background-color: var(--color-primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 1.2rem;
            box-shadow: 0 4px 10px rgba(42, 75, 53, 0.15);
